---
// Topic-Concept Map: a clean 53-node graph showing how the 18 topics and
// 35 concepts of learning engineering relate via prerequisite chains.
// Layout is computed at build time with d3-force; the SVG is fully static.

import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import {
  forceSimulation,
  forceLink,
  forceManyBody,
  forceX,
  forceY,
  forceCollide,
} from "d3-force";

// @ts-ignore — JSON imports
import topicMap from "../data/topic_map.json";
// @ts-ignore
import conceptOntology from "../data/concept_ontology.json";
// @ts-ignore
import conceptSeeds from "../data/concept_graph_seeds.json";
// @ts-ignore
import knowledgeSeeds from "../data/knowledge_graph_seeds.json";
// @ts-ignore
import seedPapersData from "../data/papers_seed.json";
// @ts-ignore
import icicleRegistry from "../data/icicle_resources_registry.json";
// @ts-ignore
import ppRegistry from "../data/programs_people_registry.json";
import { topicUrl } from "../data/topicSlugs";

const base = import.meta.env.BASE_URL;

// ── 1. Title lookups for papers and resources ─────────────────────────────

const paperTitles = new Map<string, { title: string; authors: string; year: number; url: string }>();
for (const p of (seedPapersData as any).papers ?? []) {
  paperTitles.set(p.id, {
    title: p.title,
    authors: (p.authors ?? []).join(", "),
    year: p.year ?? 0,
    url: p.source_url || "",
  });
}

const resourceTitles = new Map<string, { name: string; url: string; type: string }>();
for (const r of icicleRegistry as any[]) {
  resourceTitles.set(r.resource_id, { name: r.name, url: r.url ?? "", type: r.content_type });
}
for (const r of ppRegistry as any[]) {
  resourceTitles.set(r.resource_id, { name: r.name, url: r.url ?? "", type: r.content_type });
}

// ── 2. Content counts + per-topic item links ──────────────────────────────

function entryAnchorId(slug: string): string {
  return `entry-${slug.replace(/[^a-zA-Z0-9_-]/g, "-")}`;
}

const allItems = [
  ...(await getCollection("practice")),
  ...(await getCollection("tools")),
  ...(await getCollection("reading-list")),
  ...(await getCollection("events")),
  ...(await getCollection("community")),
];

const collectionLabels: Record<string, string> = {
  practice: "Practice",
  tools: "Tools",
  "reading-list": "Reading List",
  events: "Events",
  community: "Community",
};

const topicCounts: Record<string, number> = {};
const topicItems: Record<string, { title: string; href: string; external: boolean; collection: string }[]> = {};
for (const item of allItems) {
  const data = item.data as any;
  const itemTopics = data.topics ?? [];
  for (const t of itemTopics) {
    topicCounts[t] = (topicCounts[t] || 0) + 1;

    if (!topicItems[t]) topicItems[t] = [];

    const hasExternal = typeof data.url === "string" && /^https?:\/\//.test(data.url);
    const fallbackHref = `${topicUrl(t)}#${entryAnchorId(item.slug ?? item.id)}`;

    topicItems[t].push({
      title: data.title ?? item.slug ?? item.id,
      href: hasExternal ? data.url : fallbackHref,
      external: hasExternal,
      collection: collectionLabels[item.collection] ?? item.collection,
    });
  }
}

for (const code of Object.keys(topicItems)) {
  topicItems[code].sort((a, b) => a.collection.localeCompare(b.collection) || a.title.localeCompare(b.title));
}

// ── 3. Build concept metadata for the detail panel ────────────────────────

interface ConceptMeta {
  id: string;
  name: string;
  bloomLevel: string;
  topicCodes: string[];
  prerequisites: string[];
  papers: { id: string; title: string; authors: string }[];
  resources: { id: string; name: string; url: string }[];
}

const conceptMeta = new Map<string, ConceptMeta>();
for (const c of conceptOntology as any[]) {
  conceptMeta.set(c.concept_id, {
    id: c.concept_id,
    name: c.name,
    bloomLevel: c.bloom_level,
    topicCodes: c.topic_codes,
    prerequisites: c.prerequisites ?? [],
    papers: (c.primary_papers ?? [])
      .map((pid: string) => {
        const p = paperTitles.get(pid);
        return p ? { id: pid, title: p.title, authors: p.authors } : null;
      })
      .filter(Boolean),
    resources: (c.primary_resources ?? [])
      .map((rid: string) => {
        const r = resourceTitles.get(rid);
        return r ? { id: rid, name: r.name, url: r.url } : null;
      })
      .filter(Boolean),
  });
}

// Build child-concept lists per topic and concept name lookup
const topicChildren = new Map<string, { id: string; name: string; bloom: string }[]>();
const conceptNameById = new Map<string, string>();
for (const c of conceptOntology as any[]) {
  conceptNameById.set(c.concept_id, c.name);
  const primaryTopic = c.topic_codes[0];
  if (!topicChildren.has(primaryTopic)) topicChildren.set(primaryTopic, []);
  topicChildren.get(primaryTopic)!.push({
    id: c.concept_id,
    name: c.name,
    bloom: c.bloom_level,
  });
}

// Build full prerequisite chain (walk backwards) for each concept
function getPrereqChain(conceptId: string): string[] {
  const chain: string[] = [];
  const visited = new Set<string>();
  let current = conceptId;
  while (true) {
    const meta = conceptMeta.get(current);
    if (!meta || meta.prerequisites.length === 0) break;
    const prereq = meta.prerequisites[0];
    if (visited.has(prereq)) break;
    visited.add(prereq);
    chain.unshift(prereq);
    current = prereq;
  }
  return chain;
}

// Serialize enrichment data as JSON for the client-side script
const enrichmentData: Record<string, any> = {};

for (const [id, meta] of conceptMeta) {
  const chain = getPrereqChain(id);
  enrichmentData[id] = {
    type: "concept",
    name: meta.name,
    bloom: meta.bloomLevel,
    prereqChain: chain.map((cid) => ({ id: cid, name: conceptNameById.get(cid) ?? cid })),
    directPrereqs: meta.prerequisites.map((cid) => ({ id: cid, name: conceptNameById.get(cid) ?? cid })),
    papers: meta.papers,
    resources: meta.resources,
  };
}

for (const t of topicMap as any[]) {
  const children = topicChildren.get(t.topic_code) ?? [];
  enrichmentData[t.topic_code] = {
    type: "topic",
    name: t.topic_name,
    description: t.why_it_matters,
    contentCount: topicCounts[t.topic_code] || 0,
    siteItems: topicItems[t.topic_code] ?? [],
    children,
  };
}

// ── 4. Build graph nodes ──────────────────────────────────────────────────

interface GNode {
  id: string;
  label: string;
  nodeType: "topic" | "concept";
  layer: string;
  description: string;
  bloomLevel?: string;
  contentCount: number;
  parentTopic?: string;
  x?: number;
  y?: number;
  vx?: number;
  vy?: number;
}

const nodes: GNode[] = [
  ...topicMap.map((t: any) => ({
    id: t.topic_code,
    label: t.topic_name,
    nodeType: "topic" as const,
    layer: t.layer,
    description: t.why_it_matters,
    contentCount: topicCounts[t.topic_code] || 0,
  })),
  ...conceptOntology.map((c: any) => {
    const parentCode = c.topic_codes[0];
    const parentTopic = topicMap.find((t: any) => t.topic_code === parentCode);
    return {
      id: c.concept_id,
      label: c.name,
      nodeType: "concept" as const,
      layer: parentTopic?.layer ?? "Foundation",
      description: "",
      bloomLevel: c.bloom_level,
      contentCount: 0,
      parentTopic: parentCode,
    };
  }),
];

// ── 5. Build edges ────────────────────────────────────────────────────────

interface GEdge {
  source: string | GNode;
  target: string | GNode;
  edgeType: string;
  label?: string;
}

const edges: GEdge[] = [];

for (const e of knowledgeSeeds as any[]) {
  if (e.node_type !== "TOPIC") continue;
  if (e.edge_type === "CROSS_CUTS") continue;
  if (e.edge_type === "PREREQ_FOR" || e.edge_type === "STRONGLY_RELATED") {
    edges.push({ source: e.node_id, target: e.edge_target, edgeType: e.edge_type, label: e.edge_label });
  }
}

for (const e of conceptSeeds as any[]) {
  if (e.edge_type === "BOOK_CHAPTER") continue;
  edges.push({ source: e.node_id, target: e.edge_target, edgeType: e.edge_type, label: e.edge_label });
}

// ── 6. Run d3-force simulation ────────────────────────────────────────────

const WIDTH = 1400;
const HEIGHT = 1000;
const PADDING = 90;

const layerY: Record<string, number> = {
  Foundation: HEIGHT * 0.20,
  Practice: HEIGHT * 0.52,
  Context: HEIGHT * 0.84,
};

const layerBands = [
  { layer: "Foundation", y: 0, h: HEIGHT * 0.36 },
  { layer: "Practice",   y: HEIGHT * 0.36, h: HEIGHT * 0.30 },
  { layer: "Context",    y: HEIGHT * 0.66, h: HEIGHT * 0.34 },
];

const sim = forceSimulation(nodes as any)
  .force(
    "link",
    forceLink(edges as any)
      .id((d: any) => d.id)
      .distance((d: any) => (d.edgeType === "BELONGS_TO" ? 60 : 120))
      .strength((d: any) => (d.edgeType === "BELONGS_TO" ? 0.8 : 0.3)),
  )
  .force("charge", forceManyBody().strength(-300))
  .force("x", forceX(WIDTH / 2).strength(0.04))
  .force("y", forceY((d: any) => layerY[d.layer] ?? HEIGHT / 2).strength(0.35))
  .force("collide", forceCollide().radius((d: any) => (d.nodeType === "topic" ? 58 : 40)))
  .stop();

for (let i = 0; i < 400; i++) sim.tick();

for (const n of nodes) {
  n.x = Math.max(PADDING, Math.min(WIDTH - PADDING, n.x!));
  n.y = Math.max(PADDING / 2, Math.min(HEIGHT - PADDING / 2, n.y!));
}

// ── 7. SVG rendering helpers ──────────────────────────────────────────────

const nodeById = new Map(nodes.map((n) => [n.id, n]));

function resolveId(ref: any): string {
  return typeof ref === "string" ? ref : ref.id;
}

function truncate(s: string, max: number): string {
  return s.length > max ? s.slice(0, max - 1) + "\u2026" : s;
}

const layerFill: Record<string, string> = { Foundation: "#7a4e22", Practice: "#2c5f6f", Context: "#5a6b4a" };
const conceptFill: Record<string, string> = { Foundation: "#d4b896", Practice: "#9ec5cf", Context: "#b3c4a1" };
const layerStroke: Record<string, string> = { Foundation: "#5e3a18", Practice: "#1e4650", Context: "#3e4a34" };

const TOPIC_R = 20;
const CONCEPT_R = 9;

// ── 8. Build concept index grouped by topic, ordered by layer ─────────────

const layerOrder = ["Foundation", "Practice", "Context"];
const indexGroups = layerOrder.flatMap((layer) =>
  (topicMap as any[])
    .filter((t) => t.layer === layer)
    .map((t) => ({
      topic: t.topic_code,
      topicName: t.topic_name,
      layer,
      concepts: topicChildren.get(t.topic_code) ?? [],
    })),
);
---

<Base title="Topic Map · Learning Engineering Commons" active="graph">
  <section class="hero">
    <div class="container">
      <div class="eyebrow">Topic Map</div>
      <h1>How learning engineering connects</h1>
      <p class="subhead">
        Eighteen topics and thirty-five concepts arranged by prerequisite flow.
        Foundation topics at the top feed into Practice, which feeds into Context.
        Click any node for details — including prerequisite chains, key papers, and linked resources.
      </p>
    </div>
  </section>

  <div class="graph-layout container-wide">
    {/* ── Left: Concept Index ──────────────────────────────────────────── */}
    <aside class="concept-index" id="concept-index">
      <h2 class="index-heading">Concept Index</h2>
      {indexGroups.map((g) => (
        <div class="index-group">
          <h3 class={`index-topic layer-text--${g.layer.toLowerCase()}`}>
            <button class="index-topic-btn" data-node-id={g.topic} type="button">
              <span class="index-topic-code">{g.topic}</span>
              {g.topicName}
            </button>
          </h3>
          {g.concepts.length > 0 && (
            <ul class="index-concepts">
              {g.concepts.map((c) => (
                <li>
                  <button class="index-concept-btn" data-node-id={c.id} type="button">
                    {c.name}
                    <span class="index-bloom">{c.bloom}</span>
                  </button>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </aside>

    {/* ── Right: Graph + Detail ─────────────────────────────────────────── */}
    <div class="graph-main">
      <div class="graph-wrap">
        <svg
          viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Topic-concept map of learning engineering showing 18 topics and 35 concepts connected by prerequisite relationships"
          id="graph-svg"
        >
          <defs>
            <marker id="arrow" viewBox="0 0 10 6" refX="10" refY="3" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,3 L0,6 Z" fill="var(--muted)" />
            </marker>
            <marker id="arrow-hl" viewBox="0 0 10 6" refX="10" refY="3" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
              <path d="M0,0 L10,3 L0,6 Z" fill="var(--ink)" />
            </marker>
          </defs>

          {layerBands.map((b) => (
            <g>
              <rect x="0" y={b.y} width={WIDTH} height={b.h} class={`layer-band layer-band--${b.layer.toLowerCase()}`} />
              <text x="16" y={b.y + 22} class="layer-label">{b.layer}</text>
            </g>
          ))}

          <g class="edges">
            {edges.map((e) => {
              const srcId = resolveId(e.source);
              const tgtId = resolveId(e.target);
              const src = nodeById.get(srcId);
              const tgt = nodeById.get(tgtId);
              if (!src || !tgt) return null;
              const srcR = src.nodeType === "topic" ? TOPIC_R : CONCEPT_R;
              const tgtR = tgt.nodeType === "topic" ? TOPIC_R : CONCEPT_R;
              const dx = tgt.x! - src.x!;
              const dy = tgt.y! - src.y!;
              const dist = Math.sqrt(dx * dx + dy * dy) || 1;
              const sx = src.x! + (dx / dist) * srcR;
              const sy = src.y! + (dy / dist) * srcR;
              const tx = tgt.x! - (dx / dist) * (tgtR + 6);
              const ty = tgt.y! - (dy / dist) * (tgtR + 6);
              const cls = ["edge", e.edgeType === "BELONGS_TO" ? "edge--belongs" : "", e.edgeType === "STRONGLY_RELATED" ? "edge--related" : "", e.edgeType === "PREREQ_FOR" ? "edge--prereq" : ""].filter(Boolean).join(" ");
              return <line x1={sx} y1={sy} x2={tx} y2={ty} class={cls} data-source={srcId} data-target={tgtId} marker-end={e.edgeType === "PREREQ_FOR" ? "url(#arrow)" : undefined} />;
            })}
          </g>

          <g class="nodes">
            {nodes.map((n) => {
              const r = n.nodeType === "topic" ? TOPIC_R : CONCEPT_R;
              const fill = n.nodeType === "topic" ? layerFill[n.layer] : conceptFill[n.layer];
              const stroke = n.nodeType === "topic" ? layerStroke[n.layer] : layerFill[n.layer];
              const labelMax = n.nodeType === "topic" ? 28 : 24;
              const isCrossCuts = n.id === "T14";
              return (
                <g
                  class={`node node--${n.nodeType} layer-${n.layer.toLowerCase()}`}
                  data-id={n.id}
                  data-label={n.label}
                  data-type={n.nodeType}
                  data-layer={n.layer}
                  tabindex="0"
                  role="button"
                  aria-label={`${n.nodeType === "topic" ? "Topic" : "Concept"}: ${n.label}`}
                >
                  <title>{n.label}</title>
                  {isCrossCuts && <circle cx={n.x} cy={n.y} r={r + 6} fill="none" stroke={layerFill[n.layer]} stroke-width="1.5" stroke-dasharray="4 3" class="cross-cuts-ring" />}
                  <circle cx={n.x} cy={n.y} r={r} fill={fill} stroke={stroke} stroke-width={n.nodeType === "topic" ? 2 : 1.2} />
                  {n.nodeType === "topic" && n.contentCount > 0 && <text x={n.x} y={n.y! + 5} text-anchor="middle" class="node-count">{n.contentCount}</text>}
                  <text x={n.x} y={n.y! + r + (n.nodeType === "topic" ? 15 : 12)} text-anchor="middle" class={`node-label node-label--${n.nodeType}`}>{truncate(n.label, labelMax)}</text>
                </g>
              );
            })}
          </g>
        </svg>
      </div>

      <div class="legend">
        <div class="legend-item"><svg width="16" height="16"><circle cx="8" cy="8" r="7" fill="#7a4e22" stroke="#5e3a18" stroke-width="1.5" /></svg><span>Foundation topic</span></div>
        <div class="legend-item"><svg width="16" height="16"><circle cx="8" cy="8" r="7" fill="#2c5f6f" stroke="#1e4650" stroke-width="1.5" /></svg><span>Practice topic</span></div>
        <div class="legend-item"><svg width="16" height="16"><circle cx="8" cy="8" r="7" fill="#5a6b4a" stroke="#3e4a34" stroke-width="1.5" /></svg><span>Context topic</span></div>
        <div class="legend-item"><svg width="16" height="16"><circle cx="8" cy="8" r="5" fill="#d4b896" stroke="#7a4e22" stroke-width="1" /></svg><span>Concept</span></div>
        <div class="legend-item"><svg width="30" height="10"><line x1="0" y1="5" x2="30" y2="5" stroke="var(--muted)" stroke-width="1.2" marker-end="url(#arrow)" /></svg><span>Prerequisite</span></div>
        <div class="legend-item"><svg width="30" height="10"><line x1="0" y1="5" x2="30" y2="5" stroke="var(--muted)" stroke-width="1" stroke-dasharray="4 3" opacity="0.5" /></svg><span>Belongs to topic</span></div>
      </div>

      {/* Detail panel */}
      <div id="detail-panel" class="detail-panel" hidden>
        <button class="detail-close" aria-label="Close detail panel">&times;</button>
        <div class="detail-header">
          <span id="detail-chip" class="detail-chip"></span>
          <span id="detail-bloom" class="detail-bloom"></span>
        </div>
        <h3 id="detail-title" class="detail-title"></h3>
        <p id="detail-description" class="detail-description"></p>

        <div id="detail-prereqs" class="detail-section" hidden>
          <h4 class="detail-section-heading">Learning path</h4>
          <div id="detail-prereq-chain" class="prereq-chain"></div>
        </div>

        <div id="detail-children" class="detail-section" hidden>
          <h4 class="detail-section-heading">Concepts in this topic</h4>
          <ul id="detail-children-list" class="detail-list"></ul>
        </div>

        <div id="detail-items" class="detail-section" hidden>
          <h4 class="detail-section-heading">Associated items</h4>
          <ul id="detail-items-list" class="detail-list"></ul>
        </div>

        <div id="detail-papers" class="detail-section" hidden>
          <h4 class="detail-section-heading">Key papers</h4>
          <ul id="detail-papers-list" class="detail-list"></ul>
        </div>

        <div id="detail-resources" class="detail-section" hidden>
          <h4 class="detail-section-heading">Key resources</h4>
          <ul id="detail-resources-list" class="detail-list"></ul>
        </div>

        <p id="detail-count" class="detail-count"></p>
      </div>
    </div>
  </div>

  {/* Embedded enrichment data for client-side JS */}
  <script type="application/json" id="enrichment-data" set:html={JSON.stringify(enrichmentData)} />
</Base>

<script>
  // Interactive graph: hover, click detail panel, concept index navigation.
  const svg = document.getElementById("graph-svg")!;
  const panel = document.getElementById("detail-panel")!;
  const enrichment: Record<string, any> = JSON.parse(
    document.getElementById("enrichment-data")!.textContent!,
  );

  const allNodes = svg.querySelectorAll(".node");
  const allEdges = svg.querySelectorAll(".edge");

  // Adjacency index
  const neighbors = new Map<string, Set<string>>();
  const nodeEdges = new Map<string, Set<Element>>();

  for (const edge of allEdges) {
    const src = edge.getAttribute("data-source")!;
    const tgt = edge.getAttribute("data-target")!;
    for (const id of [src, tgt]) {
      if (!neighbors.has(id)) neighbors.set(id, new Set());
      if (!nodeEdges.has(id)) nodeEdges.set(id, new Set());
    }
    neighbors.get(src)!.add(tgt);
    neighbors.get(tgt)!.add(src);
    nodeEdges.get(src)!.add(edge);
    nodeEdges.get(tgt)!.add(edge);
  }

  function clearHighlight() {
    for (const n of allNodes) n.classList.remove("dimmed", "highlighted");
    for (const e of allEdges) {
      e.classList.remove("dimmed", "highlighted");
      if (e.getAttribute("marker-end")) e.setAttribute("marker-end", "url(#arrow)");
    }
  }

  function highlightNode(id: string) {
    const nbrs = neighbors.get(id) ?? new Set();
    const myEdges = nodeEdges.get(id) ?? new Set();
    for (const n of allNodes) {
      const nid = n.getAttribute("data-id")!;
      n.classList.toggle("highlighted", nid === id || nbrs.has(nid));
      n.classList.toggle("dimmed", nid !== id && !nbrs.has(nid));
    }
    for (const e of allEdges) {
      e.classList.toggle("highlighted", myEdges.has(e));
      e.classList.toggle("dimmed", !myEdges.has(e));
      if (myEdges.has(e) && e.getAttribute("marker-end")) {
        e.setAttribute("marker-end", "url(#arrow-hl)");
      }
    }
  }

  // Hover
  for (const node of allNodes) {
    node.addEventListener("mouseenter", () => highlightNode(node.getAttribute("data-id")!));
    node.addEventListener("mouseleave", clearHighlight);
  }

  // Detail panel elements
  const chipEl = document.getElementById("detail-chip")!;
  const bloomEl = document.getElementById("detail-bloom")!;
  const titleEl = document.getElementById("detail-title")!;
  const descEl = document.getElementById("detail-description")!;
  const prereqsSection = document.getElementById("detail-prereqs")!;
  const prereqChainEl = document.getElementById("detail-prereq-chain")!;
  const childrenSection = document.getElementById("detail-children")!;
  const childrenList = document.getElementById("detail-children-list")!;
  const itemsSection = document.getElementById("detail-items")!;
  const itemsList = document.getElementById("detail-items-list")!;
  const papersSection = document.getElementById("detail-papers")!;
  const papersList = document.getElementById("detail-papers-list")!;
  const resourcesSection = document.getElementById("detail-resources")!;
  const resourcesList = document.getElementById("detail-resources-list")!;
  const countEl = document.getElementById("detail-count")!;

  function showDetail(id: string) {
    const nodeEl = svg.querySelector(`.node[data-id="${id}"]`);
    if (!nodeEl) return;
    const label = nodeEl.getAttribute("data-label")!;
    const type = nodeEl.getAttribute("data-type")!;
    const layer = nodeEl.getAttribute("data-layer")!;
    const data = enrichment[id];
    if (!data) return;

    chipEl.textContent = type === "topic" ? `Topic ${id}` : `Concept ${id}`;
    chipEl.className = `detail-chip detail-chip--${layer.toLowerCase()}`;
    titleEl.textContent = label;

    if (data.type === "topic") {
      bloomEl.hidden = true;
      descEl.textContent = data.description;
      descEl.hidden = !data.description;

      // Child concepts
      if (data.children.length > 0) {
        childrenList.innerHTML = data.children
          .map((c: any) => `<li><button class="detail-link" data-nav="${c.id}" type="button">${c.name}</button> <span class="bloom-tag">${c.bloom}</span></li>`)
          .join("");
        childrenSection.hidden = false;
      } else {
        childrenSection.hidden = true;
      }

      prereqsSection.hidden = true;
      papersSection.hidden = true;
      resourcesSection.hidden = true;

      if (data.siteItems.length > 0) {
        itemsList.innerHTML = data.siteItems
          .map((item: any) => {
            const target = item.external ? ` target="_blank" rel="noopener"` : "";
            return `<li class="associated-item"><a href="${item.href}"${target} class="resource-link">${item.title}</a><span class="associated-meta">${item.collection}</span></li>`;
          })
          .join("");
        itemsSection.hidden = false;
      } else {
        itemsSection.hidden = true;
      }

      if (data.contentCount > 0) {
        countEl.innerHTML = `<strong>${data.contentCount}</strong> site item${data.contentCount !== 1 ? "s" : ""} tagged with this topic`;
        countEl.hidden = false;
      } else {
        countEl.textContent = "No site items tagged with this topic yet";
        countEl.hidden = false;
      }
    } else {
      // Concept
      bloomEl.textContent = `Bloom: ${data.bloom}`;
      bloomEl.hidden = false;
      descEl.hidden = true;
      childrenSection.hidden = true;
      itemsSection.hidden = true;

      // Prereq chain
      if (data.prereqChain.length > 0) {
        const steps = [
          ...data.prereqChain.map((c: any) => `<button class="chain-step" data-nav="${c.id}" type="button">${c.name}</button>`),
          `<span class="chain-current">${label}</span>`,
        ];
        prereqChainEl.innerHTML = steps.join('<span class="chain-arrow">\u2192</span>');
        prereqsSection.hidden = false;
      } else {
        prereqsSection.hidden = true;
      }

      // Key papers
      if (data.papers.length > 0) {
        papersList.innerHTML = data.papers
          .map((p: any) => `<li class="paper-item"><span class="paper-title">${p.title}</span>${p.authors ? `<span class="paper-authors">${p.authors}</span>` : ""}</li>`)
          .join("");
        papersSection.hidden = false;
      } else {
        papersSection.hidden = true;
      }

      // Key resources
      if (data.resources.length > 0) {
        resourcesList.innerHTML = data.resources
          .map((r: any) => {
            const hasUrl = r.url && r.url !== "[internal]" && r.url.startsWith("http");
            return hasUrl
              ? `<li><a href="${r.url}" target="_blank" rel="noopener" class="resource-link">${r.name}</a></li>`
              : `<li class="resource-item">${r.name}</li>`;
          })
          .join("");
        resourcesSection.hidden = false;
      } else {
        resourcesSection.hidden = true;
      }

      countEl.hidden = true;
    }

    panel.hidden = false;
    highlightNode(id);
    panel.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  // Click on graph node
  for (const node of allNodes) {
    node.addEventListener("click", () => showDetail(node.getAttribute("data-id")!));
  }

  // Close button
  panel.querySelector(".detail-close")!.addEventListener("click", () => {
    panel.hidden = true;
    clearHighlight();
  });

  // Keyboard: Enter/Space on focused node
  for (const node of allNodes) {
    node.addEventListener("keydown", (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "Enter" || ke.key === " ") { ke.preventDefault(); (node as HTMLElement).click(); }
    });
  }

  // Concept index sidebar: clicking navigates to graph node + shows detail
  document.querySelectorAll("[data-node-id]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-node-id")!;
      showDetail(id);
    });
  });

  // Detail panel internal navigation (prereq chain steps, child concepts)
  panel.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement).closest("[data-nav]");
    if (target) {
      showDetail(target.getAttribute("data-nav")!);
    }
  });
</script>

