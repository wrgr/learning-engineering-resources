---
// Explore: custom views of the KB through user-defined filters, groupings,
// and visualizations. Preserves the curated site; this is an additive lens.

import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { topicUrl, topicName } from "../data/topicSlugs";

// @ts-ignore — JSON imports
import topicMap from "../data/topic_map.json";
// @ts-ignore
import rawClusters from "../data/topic_clusters.json";
// @ts-ignore
import rawKeywords from "../data/resource_keywords.json";

const base = import.meta.env.BASE_URL;

const COLLECTIONS = ["practice", "tools", "reading-list", "events", "community"] as const;

// ── Load all resources ────────────────────────────────────────────────────

const allEntries = (
  await Promise.all(COLLECTIONS.map((c) => getCollection(c as any)))
).flat();

// ── Build lookup tables ───────────────────────────────────────────────────

const topicNames: Record<string, string> = {};
const topicLayers: Record<string, string> = {};
const topicUrls: Record<string, string> = {};
for (const t of topicMap as { topic_code: string; topic_name: string; layer: string }[]) {
  topicNames[t.topic_code] = t.topic_name;
  topicLayers[t.topic_code] = t.layer;
  topicUrls[t.topic_code] = topicUrl(t.topic_code);
}

// ── Build resource index ──────────────────────────────────────────────────

type EnrichedResource = {
  id: string;
  collection: string;
  title: string;
  format: string;
  url?: string;
  authors?: string;
  year?: number;
  venue?: string;
  summary?: string;
  topics: string[];
  keywords: string[];
  hsi_relevant: boolean;
  cluster_id: number;
};

const kw = rawKeywords as Record<string, { keywords: string[]; hsi_relevant: boolean; cluster_id: number }>;

const resources: EnrichedResource[] = allEntries.map((entry) => {
  const d = entry.data as any;
  const enriched = kw[entry.id] ?? { keywords: [], hsi_relevant: false, cluster_id: 0 };
  return {
    id: entry.id,
    collection: entry.collection,
    title: d.title,
    format: d.format,
    url: d.url,
    authors: d.authors,
    year: d.year,
    venue: d.venue,
    summary: d.summary,
    topics: d.topics ?? [],
    keywords: enriched.keywords,
    hsi_relevant: enriched.hsi_relevant,
    cluster_id: enriched.cluster_id,
  };
});

// Sort by year desc, then by title
resources.sort((a, b) => {
  if (b.year && a.year) return b.year - a.year;
  if (b.year) return 1;
  if (a.year) return -1;
  return a.title.localeCompare(b.title);
});

// ── Format list for checkboxes ────────────────────────────────────────────

const FORMAT_GROUPS = [
  { label: "Reading", formats: ["paper", "book", "article", "report", "essay", "post"] },
  { label: "Practice", formats: ["framework", "method", "template", "toolkit", "diagram"] },
  { label: "Media", formats: ["video", "podcast", "keynote", "webinar", "conference-talk"] },
  { label: "Community", formats: ["conference", "workshop", "series", "org", "program", "person", "institution"] },
  { label: "Tools", formats: ["tool", "platform"] },
];

// ── Topic groups for sidebar ──────────────────────────────────────────────

const LAYERS = ["Foundation", "Practice", "Context"] as const;
const topicsByLayer = LAYERS.map((layer) => ({
  layer,
  topics: (topicMap as any[]).filter((t) => t.layer === layer).map((t) => ({
    code: t.topic_code,
    name: t.topic_name,
  })),
}));

// ── Embed payload ─────────────────────────────────────────────────────────

const exploreData = { resources, clusters: rawClusters, topicNames, topicLayers, topicUrls };
---

<Base
  title="Explore · Learning Engineering Commons"
  description="Build a custom view of the Learning Engineering Commons knowledge base — filter by topic, semantic cluster, format, or HSI relevance."
  active="explore"
>
  <section class="hero">
    <div class="container">
      <div class="eyebrow">Explore</div>
      <h1>Build your own view</h1>
      <p class="subhead">
        The KB sits at an intersectional space — human systems integration, learning science, AI,
        and ethics often overlap in the same resource. Filter by topic, semantic cluster, or HSI
        relevance to assemble a slice of the field that matches your angle.
      </p>
    </div>
  </section>

  <div class="explore-layout container-wide">

    {/* ── Sidebar ───────────────────────────────────────────────────────── */}
    <aside class="explore-sidebar">

      <div class="sidebar-section sidebar-section--view">
        <div class="sidebar-label">View as</div>
        <div class="view-toggle">
          <button class="view-btn active" data-view="grid" type="button">Grid</button>
          <button class="view-btn" data-view="graph" type="button">Graph</button>
        </div>
      </div>

      <div class="sidebar-section">
        <label class="sidebar-label" for="group-by">Group by</label>
        <select id="group-by" class="sidebar-select">
          <option value="cluster">Semantic cluster</option>
          <option value="topic">Topic</option>
          <option value="format">Format</option>
          <option value="collection">Section</option>
        </select>
      </div>

      <div class="sidebar-section">
        <div class="sidebar-label">Topics</div>
        {topicsByLayer.map(({ layer, topics }) => (
          <div class="topic-layer">
            <div class={`topic-layer-name topic-layer-name--${layer.toLowerCase()}`}>{layer}</div>
            <div class="topic-chips">
              {topics.map((t) => (
                <button
                  class={`topic-chip topic-chip--${layer.toLowerCase()}`}
                  data-topic={t.code}
                  title={t.name}
                  type="button"
                >
                  {t.code}
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="sidebar-section">
        <label class="sidebar-label hsi-label">
          <input type="checkbox" id="hsi-toggle" />
          HSI resources only
          <span class="hsi-help" title="Human Systems Integration — resources tagged with T02 or matched by HSI keyword signals">?</span>
        </label>
      </div>

      <details class="sidebar-section sidebar-expandable">
        <summary class="sidebar-label sidebar-expandable-toggle">Format</summary>
        <div class="format-groups">
          {FORMAT_GROUPS.map(({ label, formats }) => (
            <div class="format-group">
              <div class="format-group-name">{label}</div>
              {formats.map((fmt) => (
                <label class="format-row">
                  <input type="checkbox" data-format-cb={fmt} />
                  {fmt}
                </label>
              ))}
            </div>
          ))}
        </div>
      </details>

      <details class="sidebar-section sidebar-expandable">
        <summary class="sidebar-label sidebar-expandable-toggle">Year range</summary>
        <div class="year-range">
          <input type="number" id="year-min" placeholder="From" min="1990" max="2030" class="year-input" />
          <span>–</span>
          <input type="number" id="year-max" placeholder="To" min="1990" max="2030" class="year-input" />
        </div>
      </details>

      <div class="sidebar-section">
        <label class="sidebar-label" for="keyword-search">Search</label>
        <input type="text" id="keyword-search" placeholder="Keyword, author, venue…" class="sidebar-search" />
      </div>

      <div class="sidebar-footer">
        <span id="result-count" class="result-count"></span>
        <div class="sidebar-actions">
          <button id="clear-filters" class="action-btn" type="button">Clear all</button>
          <button id="copy-link" class="action-btn action-btn--primary" type="button">Copy link</button>
        </div>
      </div>
    </aside>

    {/* ── Main content area ─────────────────────────────────────────────── */}
    <div class="explore-main">
      <div id="explore-grid"></div>
      <div id="explore-graph" class="explore-graph-wrap" hidden>
        <svg id="explore-svg" role="img" aria-label="Knowledge graph of filtered resources"></svg>
        <div id="node-popup" class="node-popup" hidden></div>
      </div>
      <div id="explore-empty" class="explore-empty" hidden>
        No resources match these filters. <button id="clear-filters-empty" class="inline-clear" type="button">Clear filters</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="explore-data" set:html={JSON.stringify(exploreData)} />
</Base>

<script>
  import "../scripts/explore-view";
  // Wire the inline clear button in the empty state (not wired by main script)
  document.getElementById("clear-filters-empty")?.addEventListener("click", () => {
    document.getElementById("clear-filters")?.click();
  });
</script>

<style>
  .hero {
    background:
      radial-gradient(38rem 14rem at 92% -8%, #e8f4f7 0%, transparent 70%),
      radial-gradient(24rem 12rem at 4% -18%, #f1ece1 0%, transparent 72%),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .hero .container { padding-top: 3rem; padding-bottom: 2rem; }
  .subhead { font-size: 1.05rem; color: var(--ink-soft); max-width: 46rem; line-height: 1.55; }

  /* ── Layout ─────────────────────────────────────────────────────────── */
  .explore-layout {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: 2rem;
    align-items: start;
    padding-top: 2rem;
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────── */
  .explore-sidebar {
    position: sticky;
    top: 4rem;
    background: var(--tint);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    font-family: var(--sans);
    font-size: .82rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }
  .sidebar-section {
    padding: .75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-section:last-child { border-bottom: none; }
  .sidebar-section--view { padding-top: .5rem; }
  .sidebar-label {
    display: block;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: .45rem;
    font-size: .78rem;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .sidebar-select {
    width: 100%;
    padding: .35rem .5rem;
    font-family: var(--sans);
    font-size: .82rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
    color: var(--ink);
  }
  .sidebar-search {
    width: 100%;
    padding: .4rem .55rem;
    font-family: var(--sans);
    font-size: .82rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
    color: var(--ink);
  }
  .sidebar-search:focus, .sidebar-select:focus { outline: 2px solid var(--accent); outline-offset: 1px; }

  /* View toggle */
  .view-toggle { display: flex; gap: .4rem; }
  .view-btn {
    flex: 1;
    padding: .35rem .6rem;
    font-family: var(--sans);
    font-size: .8rem;
    font-weight: 500;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
    color: var(--ink-soft);
    cursor: pointer;
    transition: background .12s ease, color .12s ease;
  }
  .view-btn.active {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  /* Topic chips */
  .topic-layer { margin-bottom: .5rem; }
  .topic-layer-name {
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-bottom: .3rem;
  }
  .topic-layer-name--foundation { color: #7a4e22; }
  .topic-layer-name--practice   { color: #2c5f6f; }
  .topic-layer-name--context    { color: #5a6b4a; }
  .topic-chips { display: flex; flex-wrap: wrap; gap: .25rem; }
  .topic-chip {
    padding: .2rem .45rem;
    font-size: .72rem;
    font-family: var(--mono);
    font-weight: 600;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
    cursor: pointer;
    color: var(--ink-soft);
    transition: background .1s ease, color .1s ease, border-color .1s ease;
  }
  .topic-chip--foundation { border-color: #c8a882; }
  .topic-chip--practice   { border-color: #8bbec8; }
  .topic-chip--context    { border-color: #9eb09e; }
  .topic-chip.selected {
    color: var(--bg);
    border-color: transparent;
  }
  .topic-chip--foundation.selected { background: #7a4e22; }
  .topic-chip--practice.selected   { background: #2c5f6f; }
  .topic-chip--context.selected    { background: #5a6b4a; }

  /* HSI toggle */
  .hsi-label { display: flex; align-items: center; gap: .45rem; font-weight: 500; font-size: .82rem; cursor: pointer; }
  .hsi-help {
    display: inline-flex; align-items: center; justify-content: center;
    width: 1rem; height: 1rem;
    border-radius: 50%;
    border: 1px solid var(--muted);
    font-size: .65rem;
    color: var(--muted);
    cursor: help;
    flex-shrink: 0;
  }

  /* Format groups */
  .sidebar-expandable summary { cursor: pointer; list-style: none; }
  .sidebar-expandable summary::-webkit-details-marker { display: none; }
  .sidebar-expandable-toggle::after { content: " ›"; color: var(--muted); font-weight: 400; }
  details[open] .sidebar-expandable-toggle::after { content: " ›"; transform: rotate(90deg); display: inline-block; }
  .format-groups { margin-top: .5rem; display: grid; grid-template-columns: 1fr 1fr; gap: .4rem .8rem; }
  .format-group-name { font-weight: 600; font-size: .7rem; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); grid-column: 1 / -1; margin-top: .3rem; }
  .format-row { display: flex; align-items: center; gap: .35rem; cursor: pointer; }

  /* Year range */
  .year-range { display: flex; align-items: center; gap: .4rem; margin-top: .4rem; }
  .year-input {
    width: 5.5rem;
    padding: .3rem .45rem;
    font-family: var(--sans);
    font-size: .82rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
  }

  /* Sidebar footer */
  .sidebar-footer { padding-top: .75rem; }
  .result-count { display: block; font-size: .75rem; color: var(--muted); margin-bottom: .5rem; }
  .sidebar-actions { display: flex; gap: .4rem; }
  .action-btn {
    flex: 1;
    padding: .38rem .5rem;
    font-family: var(--sans);
    font-size: .78rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
    color: var(--ink-soft);
    cursor: pointer;
  }
  .action-btn--primary {
    background: var(--accent-2);
    border-color: var(--accent-2);
    color: var(--bg);
    font-weight: 600;
  }

  /* ── Main area ──────────────────────────────────────────────────────── */
  .explore-main { min-width: 0; }

  .explore-empty {
    padding: 3rem 0;
    text-align: center;
    color: var(--muted);
    font-family: var(--sans);
    font-size: .95rem;
  }
  .inline-clear {
    background: none; border: none; color: var(--accent); cursor: pointer;
    font-family: var(--sans); font-size: .95rem; text-decoration: underline;
  }

  /* ── Grid ───────────────────────────────────────────────────────────── */
  .xgroup { margin-bottom: 2.5rem; }
  .xgroup-heading {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 .3rem;
    display: flex;
    align-items: baseline;
    gap: .5rem;
  }
  .xgroup-count {
    font-family: var(--sans);
    font-size: .8rem;
    color: var(--muted);
    font-weight: 400;
  }
  .xgroup-desc {
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--muted);
    margin: 0 0 .9rem;
    max-width: 42rem;
  }
  .xcard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17rem), 1fr));
    gap: .9rem;
  }
  :global(.xcard) {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    border-top: 3px solid var(--accent);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }
  :global(.xcard-format) {
    font-family: var(--sans);
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  :global(.xcard-title) {
    font-family: var(--serif);
    font-size: .97rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: var(--ink);
  }
  :global(.xcard-link) { color: var(--accent); border: none; }
  :global(.xcard-link:hover) { border-bottom: 1px solid var(--accent); }
  :global(.xcard-meta) {
    font-family: var(--sans);
    font-size: .75rem;
    color: var(--muted);
  }
  :global(.xcard-summary) {
    font-family: var(--sans);
    font-size: .8rem;
    color: var(--ink-soft);
    line-height: 1.45;
    margin: 0;
    max-width: none;
  }
  :global(.xcard-chips) { display: flex; flex-wrap: wrap; gap: .25rem; margin-top: .2rem; }
  :global(.chip) {
    font-family: var(--sans);
    font-size: .68rem;
    padding: .15rem .45rem;
    border-radius: 3px;
    border: none;
    font-weight: 500;
    white-space: nowrap;
    text-decoration: none;
  }
  :global(.chip--foundation) { background: #f0e6d8; color: #7a4e22; }
  :global(.chip--practice)   { background: #d8eaef; color: #2c5f6f; }
  :global(.chip--context)    { background: #dfe8da; color: #5a6b4a; }
  :global(.chip--hsi)        { background: #f4e8d8; color: #7a4e22; font-style: italic; }

  /* ── Graph ──────────────────────────────────────────────────────────── */
  .explore-graph-wrap { position: relative; }
  #explore-svg {
    width: 100%;
    height: 560px;
    background: var(--tint);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: block;
  }
  :global(.xedge) { stroke: var(--border); stroke-width: 1; }
  :global(.xhub) { cursor: pointer; }
  :global(.xhub-label) {
    font-family: var(--sans);
    font-size: 10px;
    fill: var(--ink);
    font-weight: 600;
    pointer-events: none;
  }
  :global(.xresnode) { cursor: pointer; }
  :global(.xresnode:hover) { stroke: var(--ink); stroke-width: 2; }

  .node-popup {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: min(22rem, calc(100% - 2rem));
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    box-shadow: 0 8px 24px rgba(26, 29, 26, 0.14);
    padding: 1rem 1.1rem;
    font-family: var(--sans);
    font-size: .85rem;
  }
  :global(.popup-close) {
    position: absolute;
    top: .5rem;
    right: .6rem;
    background: none;
    border: none;
    font-size: 1.2rem;
    color: var(--muted);
    cursor: pointer;
    line-height: 1;
  }
  :global(.popup-format) {
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: .3rem;
  }
  :global(.popup-title) { font-size: .95rem; margin: 0 0 .3rem; }
  :global(.popup-meta) { font-size: .75rem; color: var(--muted); }
  :global(.popup-summary) { font-size: .8rem; color: var(--ink-soft); margin: .5rem 0 0; max-width: none; }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 820px) {
    .explore-layout {
      grid-template-columns: 1fr;
    }
    .explore-sidebar {
      position: static;
      max-height: none;
    }
  }
</style>
