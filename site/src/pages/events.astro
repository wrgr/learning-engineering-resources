---
import Base from "../layouts/Base.astro";
import SectionHero from "../components/SectionHero.astro";
import Card from "../components/Card.astro";
import VideoCard from "../components/VideoCard.astro";
import { getCollection, render } from "astro:content";

const entries = await getCollection("events");

// Pre-render bodies (only needed for Card, not VideoCard).
const rendered = await Promise.all(
  entries.map(async (e) => {
    const { Content } = await render(e);
    return [e.id, Content] as const;
  }),
);
const bodyMap = new Map(rendered);

// Featured video formats render as compact thumbnail cards at the top.
const videoFormats = new Set(["video", "keynote", "webinar", "conference-talk"]);

// Group featured items by format, ordered so videos are first.
const featuredOrder = ["video", "keynote", "webinar", "conference-talk"] as const;
const featuredHeadings: Record<string, string> = {
  video: "Videos",
  keynote: "Keynotes",
  webinar: "Webinars",
  "conference-talk": "Conference talks",
};

const featuredGroups = featuredOrder
  .map((fmt) => ({
    fmt,
    heading: featuredHeadings[fmt],
    items: entries
      .filter((e) => e.data.format === fmt)
      .sort((a, b) =>
        (b.data.year ?? 0) - (a.data.year ?? 0) ||
        a.data.title.localeCompare(b.data.title),
      ),
  }))
  .filter((g) => g.items.length > 0);

// Everything else: conferences, workshops, convenings, series, podcasts.
const remainingOrder = ["conference", "series", "workshop", "convening", "podcast"];
const remainingHeadings: Record<string, string> = {
  conference: "Conferences",
  series: "Recurring series",
  workshop: "Workshops",
  convening: "Convenings",
  podcast: "Podcasts",
};
const remainingGroups = remainingOrder
  .map((fmt) => ({
    fmt,
    heading: remainingHeadings[fmt] ?? fmt,
    items: entries
      .filter((e) => e.data.format === fmt)
      .sort((a, b) => a.data.title.localeCompare(b.data.title)),
  }))
  .filter((g) => g.items.length > 0);
---

<Base title="Events · Learning Engineering Commons" active="events">
  <SectionHero
    eyebrow="Events"
    title="Conferences, workshops &amp; conversations"
    question="Where the field convenes — and the talks, podcasts, and keynotes worth watching."
    count={entries.length}
  />

  <div class="section-grid container">
    {/* Featured video sections — compact thumbnail cards, ~4 across */}
    {featuredGroups.map((group) => (
      <section class="format-group">
        <h2 class="group-heading">
          {group.heading} <span class="count muted">({group.items.length})</span>
        </h2>
        <div class="video-grid">
          {group.items.map((entry) => (
            <VideoCard
              title={entry.data.title}
              format={entry.data.format}
              url={entry.data.url}
              authors={entry.data.authors}
              venue={entry.data.venue}
              year={entry.data.year}
              embed={entry.data.embed}
              speakerName={entry.data.speakerName}
            />
          ))}
        </div>
      </section>
    ))}

    {/* Remaining groups — standard Card layout */}
    {remainingGroups.map((group) => (
      <section class="format-group">
        <h2 class="group-heading">
          {group.heading} <span class="count muted">({group.items.length})</span>
        </h2>
        <div class="grid">
          {group.items.map((entry) => {
            const Body = bodyMap.get(entry.id);
            return (
              <Card
                title={entry.data.title}
                format={entry.data.format}
                url={entry.data.url}
                venue={entry.data.venue}
                authors={entry.data.authors}
                year={entry.data.year}
                cluster={entry.data.cluster}
                topics={entry.data.topics}
                tags={entry.data.tags}
                missingProvenance={entry.data.missingProvenance}
                summary={entry.data.summary}
              >
                {Body && <Body />}
              </Card>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</Base>

<style>
  .section-grid {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .format-group { display: flex; flex-direction: column; gap: 1rem; }

  .group-heading {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--border);
    text-transform: capitalize;
  }
  .count { font-size: .9rem; font-weight: 400; }

  /* Compact grid for video/keynote/webinar cards — targets ~4 across. */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    gap: .75rem;
  }

  /* Standard grid for conferences, workshops, etc. */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1rem;
  }
</style>
