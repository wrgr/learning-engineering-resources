---
// Site-wide search page with client-side filtering over a build-time index.
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { partitionCommunity } from "../data/communityBuckets";

type SearchItem = {
  title: string;
  section: string;
  sectionLabel: string;
  format: string;
  href: string;
  topics: string[];
  meta: string;
  search: string;
};

const base = import.meta.env.BASE_URL;

const [practice, tools, readingList, events, community, fieldNotes] = await Promise.all([
  getCollection("practice"),
  getCollection("tools"),
  getCollection("reading-list"),
  getCollection("events"),
  getCollection("community"),
  getCollection("field-notes"),
]);

const { study, conferencesFromCommunity, institutions, people } = partitionCommunity(community);
const studyIds = new Set(study.map((entry) => entry.id));
const conferenceIds = new Set(conferencesFromCommunity.map((entry) => entry.id));
const institutionIds = new Set(institutions.map((entry) => entry.id));
const peopleIds = new Set(people.map((entry) => entry.id));

function searchBlob(values: Array<string | number | undefined>): string {
  return values
    .filter(Boolean)
    .join(" ")
    .toLowerCase();
}

function communityHref(entryId: string): string {
  if (peopleIds.has(entryId)) return base + "community/people/";
  if (studyIds.has(entryId)) return base + "community/programs-groups/";
  if (conferenceIds.has(entryId)) return base + "community/conferences/";
  if (institutionIds.has(entryId)) return base + "community/institutions/";
  return base + "community/";
}

function toItems(
  section: string,
  sectionLabel: string,
  entries: Array<any>,
  hrefForEntry: (entry: any) => string,
): SearchItem[] {
  return entries.map((entry) => {
    const topics = [...(entry.data.topics ?? []), ...(entry.data.tags ?? [])].filter(Boolean);
    const metaParts = [entry.data.format, entry.data.authors, entry.data.venue, entry.data.year]
      .filter(Boolean)
      .join(" · ");

    return {
      title: entry.data.title,
      section,
      sectionLabel,
      format: entry.data.format,
      href: hrefForEntry(entry),
      topics,
      meta: metaParts,
      search: searchBlob([
        entry.data.title,
        entry.data.format,
        entry.data.authors,
        entry.data.venue,
        entry.data.cluster,
        ...(entry.data.topics ?? []),
        ...(entry.data.tags ?? []),
        entry.data.summary,
      ]),
    };
  });
}

const items: SearchItem[] = [
  ...toItems("practice", "Practice", practice, () => base + "practice/"),
  ...toItems("tools", "Tools", tools, () => base + "tools/"),
  ...toItems("reading-list", "Reading list", readingList, () => base + "reading-list/"),
  ...toItems("events", "Events", events, () => base + "events/"),
  ...toItems("community", "Community", community, (entry) => communityHref(entry.id)),
  ...fieldNotes
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({
      title: entry.data.title,
      section: "field-notes",
      sectionLabel: "Field notes",
      format: "field-note",
      href: base + "field-notes/",
      topics: entry.data.tags ?? [],
      meta: entry.data.summary,
      search: searchBlob([entry.data.title, entry.data.summary, ...(entry.data.tags ?? [])]),
    })),
].sort((a, b) => a.title.localeCompare(b.title));

const sectionOptions = Array.from(new Set(items.map((item) => item.section))).sort((a, b) => a.localeCompare(b));
const sectionLabels = new Map([
  ["community", "Community"],
  ["events", "Events"],
  ["field-notes", "Field notes"],
  ["practice", "Practice"],
  ["reading-list", "Reading list"],
  ["tools", "Tools"],
]);
const typeOptions = Array.from(new Set(items.map((item) => item.format))).sort((a, b) => a.localeCompare(b));
const topicOptions = Array.from(
  new Set(items.flatMap((item) => item.topics).filter(Boolean)),
).sort((a, b) => a.localeCompare(b));

function topicsBlob(topics: string[]): string {
  return topics.map((topic) => topic.toLowerCase()).join("|");
}
---

<Base title="Search · Learning Engineering Commons" active="search">
  <header class="search-hero">
    <div class="container-wide">
      <div class="eyebrow">Search</div>
      <h1>Find anything across the commons.</h1>
      <p class="subhead">
        One index across Practice, Tools, Reading List, Events, Community, and Field Notes.
      </p>
    </div>
  </header>

  <div class="container-wide search-shell" data-site-search-root>
    <section class="filter-shell">
      <div class="filter-row">
        <label class="filter-input">
          <span>Search</span>
          <input data-site-search-input type="search" placeholder="Title, author, venue, topic..." />
        </label>
        <label class="filter-input">
          <span>Section</span>
          <select data-site-search-section>
            <option value="all">All sections</option>
            {sectionOptions.map((section) => (
              <option value={section}>{sectionLabels.get(section) ?? section}</option>
            ))}
          </select>
        </label>
        <label class="filter-input">
          <span>Type</span>
          <select data-site-search-type>
            <option value="all">All types</option>
            {typeOptions.map((type) => <option value={type}>{type}</option>)}
          </select>
        </label>
        <label class="filter-input">
          <span>Topic/Tag</span>
          <select data-site-search-topic>
            <option value="all">All topics/tags</option>
            {topicOptions.map((topic) => <option value={topic.toLowerCase()}>{topic}</option>)}
          </select>
        </label>
      </div>
      <p class="filter-meta"><span data-site-search-count>{items.length}</span> results shown</p>
      <p class="filter-empty" data-site-search-empty hidden>
        No results match these filters.
      </p>
    </section>

    <section class="results" aria-live="polite">
      {items.map((item) => (
        <article
          class="result"
          data-site-item
          data-section={item.section}
          data-format={item.format}
          data-topics={topicsBlob(item.topics)}
          data-search={item.search}
        >
          <h2 class="result-title"><a href={item.href}>{item.title}</a></h2>
          <p class="result-meta">
            <span class="chip">{item.sectionLabel}</span>
            <span class="chip">{item.format}</span>
            {item.meta && <span>{item.meta}</span>}
          </p>
          {item.topics.length > 0 && (
            <p class="result-topics">{item.topics.slice(0, 6).join(" · ")}</p>
          )}
        </article>
      ))}
    </section>
  </div>

  <script type="module" src={base + "scripts/site-search.js"}></script>
</Base>

<style>
  .search-hero {
    border-bottom: 1px solid var(--border);
    background: var(--tint);
  }
  .search-hero .container-wide {
    padding-top: 2.5rem;
    padding-bottom: 1.8rem;
  }
  .subhead {
    margin: 0;
    font-size: 1rem;
    color: var(--ink-soft);
    max-width: 40rem;
  }
  .search-shell {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .filter-shell {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: .9rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
  }
  .filter-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: .65rem;
  }
  .filter-input {
    display: flex;
    flex-direction: column;
    gap: .25rem;
    font-family: var(--sans);
    font-size: .74rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .filter-input input,
  .filter-input select {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg);
    color: var(--ink);
    font-size: .9rem;
    padding: .45rem .55rem;
    font-family: var(--sans);
    text-transform: none;
    letter-spacing: normal;
  }
  .filter-meta {
    margin: 0;
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--muted);
  }
  .filter-empty {
    margin: 0;
    font-family: var(--sans);
    font-size: .86rem;
    color: var(--muted);
    background: var(--tint);
    border-radius: 3px;
    padding: .6rem .7rem;
  }
  .results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: .8rem;
  }
  .result {
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    padding: .85rem .9rem;
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }
  .result-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
  }
  .result-title a {
    color: var(--ink);
    border-bottom-color: transparent;
  }
  .result-title a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .result-meta {
    margin: 0;
    font-family: var(--sans);
    color: var(--muted);
    font-size: .78rem;
    display: flex;
    flex-wrap: wrap;
    gap: .35rem;
    align-items: center;
  }
  .chip {
    border: 1px solid var(--border);
    background: var(--tint);
    border-radius: 2px;
    padding: .08rem .3rem;
    color: var(--ink-soft);
    text-transform: capitalize;
  }
  .result-topics {
    margin: 0;
    font-family: var(--sans);
    font-size: .78rem;
    color: var(--muted);
  }
</style>
