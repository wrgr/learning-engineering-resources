---
/**
 * Dynamic topic landing page. One page per topic code (T00–T17).
 * Shows concepts, tagged content, and prerequisite/next-topic navigation.
 */

import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import { getCollection } from "astro:content";

// @ts-ignore — JSON imports
import topicMap from "../../data/topic_map.json";
// @ts-ignore
import conceptOntology from "../../data/concept_ontology.json";
// @ts-ignore
import knowledgeSeeds from "../../data/knowledge_graph_seeds.json";

import { topicSlug, topicUrl, topicName } from "../../data/topicSlugs";

const base = import.meta.env.BASE_URL;

// ── getStaticPaths: one page per topic ───────────────────────────────────
export async function getStaticPaths() {
  return (topicMap as any[]).map((t) => ({
    params: { topic: topicSlug(t.topic_code) },
    props: { topicCode: t.topic_code },
  }));
}

const { topicCode } = Astro.props;
const topic = (topicMap as any[]).find((t) => t.topic_code === topicCode)!;

// ── Concepts belonging to this topic ─────────────────────────────────────
const concepts = (conceptOntology as any[])
  .filter((c) => c.topic_codes.includes(topicCode))
  .map((c) => ({
    id: c.concept_id,
    name: c.name,
    bloom: c.bloom_level,
    prerequisites: (c.prerequisites ?? []).map((pid: string) => {
      const pre = (conceptOntology as any[]).find((x) => x.concept_id === pid);
      return pre ? { id: pid, name: pre.name } : { id: pid, name: pid };
    }),
  }));

// ── Topic navigation from knowledge graph seeds ─────────────────────────
const prereqTopics: { code: string; name: string; label: string }[] = [];
const nextTopics: { code: string; name: string; label: string }[] = [];
const relatedTopics: { code: string; name: string; label: string }[] = [];

for (const e of knowledgeSeeds as any[]) {
  if (e.node_type !== "TOPIC") continue;
  if (e.edge_type === "CROSS_CUTS") continue;

  if (e.edge_type === "PREREQ_FOR" && e.edge_target === topicCode) {
    prereqTopics.push({ code: e.node_id, name: topicName(e.node_id), label: e.edge_label });
  }
  if (e.edge_type === "PREREQ_FOR" && e.node_id === topicCode) {
    nextTopics.push({ code: e.edge_target, name: topicName(e.edge_target), label: e.edge_label });
  }
  if (e.edge_type === "STRONGLY_RELATED" && (e.node_id === topicCode || e.edge_target === topicCode)) {
    const other = e.node_id === topicCode ? e.edge_target : e.node_id;
    relatedTopics.push({ code: other, name: topicName(other), label: e.edge_label });
  }
}

// ── Content tagged with this topic ───────────────────────────────────────
type CollectionName = "reading-list" | "practice" | "tools" | "events" | "community";
const collectionLabels: Record<CollectionName, string> = {
  "reading-list": "Reading List",
  practice: "Practice",
  tools: "Tools",
  events: "Events",
  community: "Community",
};

const collections: CollectionName[] = ["reading-list", "practice", "tools", "events", "community"];
const contentGroups: { label: string; items: any[] }[] = [];

for (const coll of collections) {
  const all = await getCollection(coll);
  const matched = all.filter((item) => ((item.data as any).topics ?? []).includes(topicCode));
  if (matched.length > 0) {
    contentGroups.push({ label: collectionLabels[coll], items: matched });
  }
}

const totalContent = contentGroups.reduce((sum, g) => sum + g.items.length, 0);

// ── Layer info ───────────────────────────────────────────────────────────
const layerClass = topic.layer.toLowerCase();

const bloomColors: Record<string, string> = {
  Understand: "#7a4e22",
  Apply: "#2c5f6f",
  Analyze: "#5a6b4a",
  Evaluate: "#6b3a6b",
  Create: "#3a5e6b",
};

function entryAnchorId(slug: string): string {
  return `entry-${slug.replace(/[^a-zA-Z0-9_-]/g, "-")}`;
}
---

<Base title={`${topic.topic_name} · Topics`} active="topics">
  <header class={`topic-hero topic-hero--${layerClass}`}>
    <div class="container">
      <div class="hero-breadcrumb">
        <a href={base + "topics/"}>Topics</a>
        <span class="sep">/</span>
        <span class={`hero-layer hero-layer--${layerClass}`}>{topic.layer}</span>
      </div>
      <div class="hero-code-row">
        <span class={`hero-code hero-code--${layerClass}`}>{topicCode}</span>
      </div>
      <h1>{topic.topic_name}</h1>
      <p class="hero-desc">{topic.why_it_matters}</p>
      {totalContent > 0 && (
        <p class="hero-count">{totalContent} resource{totalContent !== 1 ? "s" : ""} tagged with this topic</p>
      )}
    </div>
  </header>

  {/* ── Topic navigation ─────────────────────────────────────────────── */}
  {(prereqTopics.length > 0 || nextTopics.length > 0 || relatedTopics.length > 0) && (
    <section class="topic-nav">
      <div class="container">
        <div class="nav-row">
          {prereqTopics.length > 0 && (
            <div class="nav-group">
              <h3 class="nav-label">Prerequisites</h3>
              {prereqTopics.map((t) => (
                <a href={topicUrl(t.code)} class={`nav-pill nav-pill--${layerClass}`} title={t.label}>
                  {t.code} {t.name}
                </a>
              ))}
            </div>
          )}
          {nextTopics.length > 0 && (
            <div class="nav-group">
              <h3 class="nav-label">Explore next</h3>
              {nextTopics.map((t) => (
                <a href={topicUrl(t.code)} class="nav-pill" title={t.label}>
                  {t.code} {t.name} &rarr;
                </a>
              ))}
            </div>
          )}
          {relatedTopics.length > 0 && (
            <div class="nav-group">
              <h3 class="nav-label">Related</h3>
              {relatedTopics.map((t) => (
                <a href={topicUrl(t.code)} class="nav-pill nav-pill--related" title={t.label}>
                  {t.code} {t.name}
                </a>
              ))}
            </div>
          )}
        </div>
        <a href={base + "graph/"} class="graph-link">View in topic map &rarr;</a>
      </div>
    </section>
  )}

  {/* ── Concepts ──────────────────────────────────────────────────────── */}
  {concepts.length > 0 && (
    <section class="concepts-section">
      <div class="container">
        <h2>Concepts in this topic</h2>
        <div class="concept-list">
          {concepts.map((c) => (
            <div class="concept-item">
              <div class="concept-header">
                <span class="concept-name">{c.name}</span>
                <span class="bloom-badge" style={`color: ${bloomColors[c.bloom] ?? "var(--muted)"}`}>
                  {c.bloom}
                </span>
              </div>
              {c.prerequisites.length > 0 && (
                <p class="concept-prereqs">
                  Builds on: {c.prerequisites.map((p: any) => p.name).join(", ")}
                </p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Content groups ────────────────────────────────────────────────── */}
  {contentGroups.length > 0 ? (
    <section class="content-section">
      <div class="container">
        <h2>Resources</h2>
        {contentGroups.map((group) => (
          <div class="content-group">
            <h3 class="group-heading">
              {group.label}
              <span class="group-count">{group.items.length}</span>
            </h3>
            <div class="card-grid">
              {group.items.map((item: any) => (
                <div id={entryAnchorId(item.slug ?? item.id)} class="topic-item-anchor">
                  <Card
                    title={item.data.title}
                    format={item.data.format}
                    url={item.data.url}
                    venue={item.data.venue}
                    authors={item.data.authors}
                    year={item.data.year}
                    cluster={item.data.cluster}
                    topics={item.data.topics}
                    tags={item.data.tags}
                    missingProvenance={item.data.missingProvenance}
                    summary={item.data.summary}
                  />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  ) : (
    <section class="content-section">
      <div class="container">
        <p class="empty-note">
          No resources tagged with this topic yet. Check back as the corpus grows, or
          <a href={base + "graph/"}>explore the topic map</a> to find related areas.
        </p>
      </div>
    </section>
  )}
</Base>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────── */
  .topic-hero {
    border-bottom: 1px solid var(--border);
    background: var(--tint);
  }
  .topic-hero .container { padding-top: 2.5rem; padding-bottom: 2rem; }

  .hero-breadcrumb {
    font-family: var(--sans);
    font-size: .78rem;
    color: var(--muted);
    margin-bottom: .8rem;
  }
  .hero-breadcrumb a { color: var(--accent); }
  .hero-breadcrumb .sep { margin: 0 .3rem; }

  .hero-code-row { margin-bottom: .4rem; }
  .hero-code {
    font-family: var(--sans);
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .08em;
    padding: .15rem .45rem;
    border-radius: 2px;
    color: #fff;
  }
  .hero-code--foundation { background: #7a4e22; }
  .hero-code--practice   { background: #2c5f6f; }
  .hero-code--context    { background: #5a6b4a; }

  .hero-layer {
    font-family: var(--sans);
    font-size: .78rem;
    font-weight: 500;
  }
  .hero-layer--foundation { color: #7a4e22; }
  .hero-layer--practice   { color: #2c5f6f; }
  .hero-layer--context    { color: #5a6b4a; }

  .topic-hero h1 {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 500;
    margin: 0 0 .6rem;
    max-width: 36rem;
  }

  .hero-desc {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: var(--measure);
    margin: 0;
  }

  .hero-count {
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--accent);
    font-weight: 500;
    margin: .6rem 0 0;
  }

  /* ── Topic navigation ─────────────────────────────────────────────── */
  .topic-nav {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 1.2rem 0;
  }
  .nav-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .nav-group { display: flex; flex-wrap: wrap; align-items: center; gap: .4rem; }
  .nav-label {
    font-family: var(--sans);
    font-size: .68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    margin: 0 .3rem 0 0;
  }
  .nav-pill {
    font-family: var(--sans);
    font-size: .78rem;
    padding: .25rem .6rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--ink-soft);
    background: var(--tint);
  }
  .nav-pill:hover { border-color: var(--accent); color: var(--accent); }
  .nav-pill--related { border-style: dashed; }

  .graph-link {
    display: inline-block;
    margin-top: .8rem;
    font-family: var(--sans);
    font-size: .78rem;
    color: var(--accent);
  }

  /* ── Concepts ─────────────────────────────────────────────────────── */
  .concepts-section { padding: 2rem 0 1rem; }
  .concepts-section h2 {
    font-family: var(--serif);
    font-size: 1.15rem;
    margin: 0 0 1rem;
  }
  .concept-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: .8rem;
  }
  .concept-item {
    padding: .7rem .9rem;
    background: var(--tint);
    border: 1px solid var(--border);
    border-radius: 3px;
  }
  .concept-header { display: flex; justify-content: space-between; align-items: center; gap: .5rem; }
  .concept-name {
    font-family: var(--sans);
    font-size: .88rem;
    font-weight: 600;
    color: var(--ink);
  }
  .bloom-badge {
    font-family: var(--sans);
    font-size: .65rem;
    font-style: italic;
    flex-shrink: 0;
  }
  .concept-prereqs {
    font-family: var(--sans);
    font-size: .72rem;
    color: var(--muted);
    margin: .3rem 0 0;
  }

  /* ── Content ──────────────────────────────────────────────────────── */
  .content-section { padding: 2rem 0 2rem; }
  .content-section h2 {
    font-family: var(--serif);
    font-size: 1.15rem;
    margin: 0 0 1.2rem;
  }
  .content-group { margin-bottom: 2rem; }
  .topic-item-anchor { scroll-margin-top: 5.5rem; }
  .group-heading {
    font-family: var(--sans);
    font-size: .85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--muted);
    margin: 0 0 .8rem;
    display: flex;
    align-items: baseline;
    gap: .4rem;
  }
  .group-count {
    font-size: .72rem;
    font-weight: 400;
    background: var(--tint);
    padding: .1rem .35rem;
    border-radius: 2px;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  .empty-note {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink-soft);
    font-style: italic;
    max-width: var(--measure);
    padding: 2rem 0;
  }
  .empty-note a { color: var(--accent); }
</style>
