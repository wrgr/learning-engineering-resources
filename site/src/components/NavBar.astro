---
// Top navigation. Two parallel renderings:
//   - Desktop (>=900px): plain horizontal <nav class="desktop-nav">
//   - Mobile/tablet (<900px): collapsed <details> disclosure with a hamburger
// Each shows the same link list; CSS swaps which one is visible.
// No JavaScript.

interface Props {
  active?: string;
}

const { active } = Astro.props;

const base = import.meta.env.BASE_URL;

const items = [
  { href: base,                   label: "Welcome",      slug: "welcome" },
  { href: base + "graph/",        label: "Graph",        slug: "graph" },
  { href: base + "practice/",     label: "Practice",     slug: "practice" },
  { href: base + "tools/",        label: "Tools",        slug: "tools" },
  { href: base + "field-notes/",  label: "Field Notes",  slug: "field-notes" },
  { href: base + "reading-list/", label: "Reading List", slug: "reading-list" },
  { href: base + "events/",       label: "Events",       slug: "events" },
  { href: base + "community/",    label: "Community",    slug: "community" },
  { href: base + "topics/",       label: "Topics",       slug: "topics" },
  { href: base + "pathways/",     label: "Pathways",     slug: "pathways" },
  { href: base + "search/",       label: "Search",       slug: "search" },
  { href: base + "about/",        label: "About",        slug: "about" },
];

const activeLabel = items.find((it) => it.slug === active)?.label ?? "Menu";
---

<header class="site-nav">
  <div class="nav-inner">
    <a href={base} class="brand" aria-label="Home">
      <span class="brand-mark">LEC</span>
      <span class="brand-text">Learning Engineering Commons</span>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        {items.map((it) => (
          <li>
            <a href={it.href} class:list={[{ active: it.slug === active }]}>
              {it.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <details class="mobile-nav">
      <summary aria-label="Toggle navigation menu">
        <span class="current">{activeLabel}</span>
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </summary>
      <nav aria-label="Primary (mobile)">
        <ul>
          {items.map((it) => (
            <li>
              <a href={it.href} class:list={[{ active: it.slug === active }]}>
                {it.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-nav {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: .75rem var(--page-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    color: var(--ink);
    border: none;
    font-family: var(--serif);
    flex-shrink: 0;
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--sans);
    font-size: .8rem;
    font-weight: 700;
    border-radius: 2px;
  }
  .brand-text { font-size: 1rem; font-weight: 600; white-space: nowrap; }

  /* ── Desktop nav (hidden below 900px) ─────────────────────────────────── */
  .desktop-nav { display: none; }
  .desktop-nav ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: .1rem;
    justify-content: flex-end;
  }
  .desktop-nav a {
    font-family: var(--sans);
    font-size: .85rem;
    color: var(--ink-soft);
    border: none;
    padding: .35rem .65rem;
    border-radius: 3px;
    white-space: nowrap;
  }
  .desktop-nav a:hover { background: var(--tint); color: var(--accent); }
  .desktop-nav a.active {
    color: var(--accent);
    background: var(--tint-warm);
  }

  /* ── Mobile nav (visible below 900px) ─────────────────────────────────── */
  .mobile-nav {
    width: 100%;
    flex: 0 0 100%;
    display: flex;
    justify-content: flex-end;
    position: relative;
  }
  .mobile-nav summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .35rem .65rem;
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--ink-soft);
    background: var(--tint);
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    margin-left: auto;
    user-select: none;
    white-space: nowrap;
  }
  .mobile-nav summary::-webkit-details-marker { display: none; }
  .mobile-nav summary .current {
    font-weight: 500;
    color: var(--accent);
    letter-spacing: .02em;
  }
  .mobile-nav[open] summary {
    background: var(--tint-warm);
    border-color: var(--accent);
    color: var(--accent);
  }
  .mobile-nav nav {
    position: absolute;
    right: 0;
    top: calc(100% + .45rem);
    width: min(19rem, calc(100vw - (var(--page-pad) * 2)));
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    box-shadow: 0 8px 24px rgba(26, 29, 26, 0.12);
    overflow: hidden;
  }
  .mobile-nav ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
  }
  .mobile-nav nav a {
    display: block;
    font-family: var(--sans);
    font-size: .95rem;
    color: var(--ink-soft);
    border: none;
    padding: .6rem .5rem;
    border-bottom: 1px solid var(--border);
  }
  .mobile-nav nav a:hover { background: var(--tint); color: var(--accent); }
  .mobile-nav nav a.active {
    color: var(--accent);
    background: var(--tint-warm);
    font-weight: 600;
  }

  @media (max-width: 620px) {
    .brand-text {
      font-size: .9rem;
      max-width: 13ch;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }

  @media (max-width: 460px) {
    .brand-text { display: none; }
    .nav-inner { gap: .55rem; }
    .mobile-nav summary { padding: .35rem .5rem; }
    .mobile-nav summary .current { display: none; }
    .mobile-nav nav { width: min(16rem, calc(100vw - (var(--page-pad) * 2))); }
  }

  /* ── Swap at 900px ────────────────────────────────────────────────────── */
  @media (min-width: 900px) {
    .nav-inner { flex-wrap: nowrap; }
    .desktop-nav { display: block; }
    .mobile-nav  { display: none; }
  }
</style>
