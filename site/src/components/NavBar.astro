---
// Top navigation — same on every page. `active` matches the slug of the current page.

interface Props {
  active?: string;
}

const { active } = Astro.props;

const items = [
  { href: "/",              label: "Welcome",      slug: "welcome" },
  { href: "/practice/",     label: "Practice",     slug: "practice" },
  { href: "/tools/",        label: "Tools",        slug: "tools" },
  { href: "/field-notes/",  label: "Field Notes",  slug: "field-notes" },
  { href: "/reading-list/", label: "Reading List", slug: "reading-list" },
  { href: "/events/",       label: "Events",       slug: "events" },
  { href: "/community/",    label: "Community",    slug: "community" },
  { href: "/about/",        label: "About",        slug: "about" },
];
---

<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Home">
      <span class="brand-mark">LE</span>
      <span class="brand-text">Learning Engineering</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {items.map((it) => (
          <li>
            <a href={it.href} class:list={[{ active: it.slug === active }]}>
              {it.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(1.2);
  }
  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: .9rem var(--page-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    color: var(--ink);
    border: none;
    font-family: var(--serif);
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--sans);
    font-size: .8rem;
    font-weight: 700;
    border-radius: 2px;
  }
  .brand-text { font-size: 1rem; font-weight: 600; }

  nav ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: .1rem;
  }
  nav a {
    font-family: var(--sans);
    font-size: .85rem;
    color: var(--ink-soft);
    border: none;
    padding: .35rem .65rem;
    border-radius: 3px;
    white-space: nowrap;
  }
  nav a:hover { background: var(--tint); color: var(--accent); }
  nav a.active {
    color: var(--accent);
    background: var(--tint-warm);
  }

  @media (max-width: 820px) {
    .nav-inner { flex-direction: column; align-items: flex-start; gap: .6rem; }
    .brand-text { font-size: .95rem; }
    nav a { font-size: .8rem; padding: .3rem .5rem; }
  }
</style>
