---
// Compact video card with YouTube thumbnail, title, and byline.
// Designed to sit in a 4-across grid for video, keynote, and webinar sections.

interface Props {
  title: string;
  format: string;
  url?: string;
  authors?: string;
  venue?: string;
  year?: number;
  embed?: string;
  speakerName?: string;
}

const { title, format, url, authors, venue, year, embed, speakerName } = Astro.props;

const formatLabel: Record<string, string> = {
  video: "Video",
  keynote: "Keynote",
  webinar: "Webinar",
  "conference-talk": "Talk",
  podcast: "Podcast",
};

function extractYouTubeId(value?: string): string | undefined {
  if (!value) return undefined;
  const embedMatch = value.match(/youtube\.com\/embed\/([A-Za-z0-9_-]{6,})/);
  if (embedMatch) return embedMatch[1];
  const watchMatch = value.match(/[?&]v=([A-Za-z0-9_-]{6,})/);
  if (watchMatch) return watchMatch[1];
  const shortMatch = value.match(/youtu\.be\/([A-Za-z0-9_-]{6,})/);
  if (shortMatch) return shortMatch[1];
  return undefined;
}

const ytId = extractYouTubeId(embed) ?? extractYouTubeId(url);
const ytThumb = ytId ? `https://i.ytimg.com/vi/${ytId}/mqdefault.jpg` : undefined;
const speaker = speakerName ?? authors;
---

<a class="vcard" href={url} target="_blank" rel="noopener">
  {ytThumb ? (
    <div class="vcard-thumb">
      <img src={ytThumb} alt={`Thumbnail for ${title}`} loading="lazy" />
      <div class="play-badge" aria-hidden="true">&#9654;</div>
    </div>
  ) : (
    <div class="vcard-thumb vcard-thumb--placeholder">
      <div class="play-badge play-badge--solo" aria-hidden="true">&#9654;</div>
    </div>
  )}
  <div class="vcard-body">
    <span class="vcard-format">{formatLabel[format] ?? format}</span>
    <h3 class="vcard-title">{title}</h3>
    {(speaker || venue || year) && (
      <p class="vcard-byline">
        {speaker && <span class="vcard-speaker">{speaker}</span>}
        {speaker && (venue || year) && <span class="sep"> · </span>}
        {venue && <span>{venue}</span>}
        {venue && year && <span class="sep"> · </span>}
        {year && <span>{year}</span>}
      </p>
    )}
  </div>
</a>

<style>
  .vcard {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color .15s ease, transform .15s ease;
    color: var(--ink);
    text-decoration: none;
  }
  .vcard:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .vcard-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #111;
    overflow: hidden;
  }
  .vcard-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .vcard-thumb--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1d1a 0%, #2c5f6f 100%);
  }

  .play-badge {
    position: absolute;
    bottom: .4rem;
    right: .4rem;
    width: 1.6rem;
    height: 1.6rem;
    background: rgba(0, 0, 0, .7);
    color: #fff;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .6rem;
    line-height: 1;
  }
  .play-badge--solo {
    position: static;
    width: 2.4rem;
    height: 2.4rem;
    font-size: .9rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, .2);
  }

  .vcard-body {
    padding: .6rem .75rem .75rem;
    display: flex;
    flex-direction: column;
    gap: .25rem;
    flex: 1;
  }

  .vcard-format {
    font-family: var(--sans);
    font-size: .6rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .vcard-title {
    font-family: var(--serif);
    font-size: .88rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .vcard:hover .vcard-title { color: var(--accent); }

  .vcard-byline {
    font-family: var(--sans);
    font-size: .7rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.4;
  }
  .vcard-speaker { font-weight: 600; color: var(--ink-soft); }
  .sep { margin: 0 .1rem; }
</style>
