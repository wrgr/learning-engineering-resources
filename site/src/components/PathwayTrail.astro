---
/**
 * Renders a single narrative pathway: title, description, topic sequence
 * with arrows, highlighted resource cards, and "go deeper" links.
 */

interface TopicStop {
  code: string;
  name: string;
  layer: string;
  href: string;
  highlights: { title: string; format: string; url?: string; authors?: string; venue?: string; year?: number }[];
}

interface Props {
  id: string;
  title: string;
  theme: string;
  description: string;
  stops: TopicStop[];
}

const { id, title, theme, description, stops } = Astro.props;

const formatLabel: Record<string, string> = {
  paper: "Paper", book: "Book", article: "Article", report: "Report",
  tool: "Tool", platform: "Platform", video: "Video", webinar: "Webinar",
  keynote: "Keynote", conference: "Conference", "conference-talk": "Talk",
  post: "Post", framework: "Framework",
};
---

<div class="trail" id={`trail-${id}`}>
  <div class="trail-header">
    <span class="trail-theme">{theme}</span>
    <h3 class="trail-title">{title}</h3>
    <p class="trail-desc">{description}</p>
  </div>

  <div class="trail-sequence">
    {stops.map((stop, i) => (
      <div class="trail-stop-group">
        {i > 0 && <span class="trail-arrow">&rarr;</span>}
        <a href={stop.href} class={`trail-stop trail-stop--${stop.layer.toLowerCase()}`}>
          <span class="stop-code">{stop.code}</span>
          <span class="stop-name">{stop.name}</span>
        </a>
      </div>
    ))}
  </div>

  <div class="trail-highlights">
    {stops.map((stop) => (
      stop.highlights.length > 0 && (
        <div class="highlight-group">
          <h4 class="highlight-topic">{stop.code} {stop.name}</h4>
          <ul class="highlight-list">
            {stop.highlights.map((h) => (
              <li class="highlight-item">
                <span class="hl-format">{formatLabel[h.format] ?? h.format}</span>
                {h.url ? (
                  <a href={h.url} target="_blank" rel="noopener" class="hl-title">{h.title}</a>
                ) : (
                  <span class="hl-title">{h.title}</span>
                )}
                {(h.authors || h.venue || h.year) && (
                  <span class="hl-meta">
                    {h.authors && <span>{h.authors}</span>}
                    {h.authors && (h.venue || h.year) && <span> · </span>}
                    {h.venue && <span>{h.venue}</span>}
                    {h.venue && h.year && <span> · </span>}
                    {h.year && <span>{h.year}</span>}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    ))}
  </div>
</div>

<style>
  .trail {
    padding: 2rem 0;
  }

  .trail-header { margin-bottom: 1.2rem; }

  .trail-theme {
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .trail-title {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 600;
    margin: .2rem 0 .5rem;
  }

  .trail-desc {
    font-size: .95rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: var(--measure);
    margin: 0;
  }

  /* ── Topic sequence ─────────────────────────────────────────────── */
  .trail-sequence {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: .4rem;
    margin: 1rem 0 1.5rem;
  }

  .trail-stop-group {
    display: flex;
    align-items: center;
    gap: .4rem;
  }

  .trail-arrow {
    color: var(--muted);
    font-size: .9rem;
  }

  .trail-stop {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    padding: .35rem .7rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--tint);
    color: var(--ink);
    font-family: var(--sans);
    font-size: .82rem;
    transition: border-color .15s ease, background .15s ease;
  }
  .trail-stop:hover {
    border-color: var(--accent);
    background: var(--tint-warm);
  }

  .stop-code {
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .06em;
    padding: .1rem .3rem;
    border-radius: 2px;
    color: #fff;
  }
  .trail-stop--foundation .stop-code { background: #7a4e22; }
  .trail-stop--practice .stop-code   { background: #2c5f6f; }
  .trail-stop--context .stop-code    { background: #5a6b4a; }

  .stop-name { font-weight: 500; }

  /* ── Highlighted resources ──────────────────────────────────────── */
  .trail-highlights {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  .highlight-group {
    border-left: 2px solid var(--border);
    padding-left: .9rem;
  }

  .highlight-topic {
    font-family: var(--sans);
    font-size: .72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--muted);
    margin: 0 0 .4rem;
  }

  .highlight-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .highlight-item {
    display: flex;
    flex-direction: column;
    gap: .15rem;
    padding: .4rem 0;
    border-bottom: 1px solid var(--border);
  }
  .highlight-item:last-child { border-bottom: none; }

  .hl-format {
    font-family: var(--sans);
    font-size: .62rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hl-title {
    font-family: var(--serif);
    font-size: .9rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
  }
  a.hl-title:hover { color: var(--accent); }

  .hl-meta {
    font-family: var(--sans);
    font-size: .72rem;
    color: var(--muted);
  }
</style>
