---
/** Clickable card for a single topic, used on the topic index and pathways pages. */

interface Props {
  code: string;
  name: string;
  layer: string;
  description: string;
  contentCount: number;
  conceptCount: number;
  href: string;
}

const { code, name, layer, description, contentCount, conceptCount, href } = Astro.props;

const layerClass = layer.toLowerCase();
---

<a href={href} class={`topic-card topic-card--${layerClass}`}>
  <div class="tc-header">
    <span class={`tc-code tc-code--${layerClass}`}>{code}</span>
    <span class={`tc-layer tc-layer--${layerClass}`}>{layer}</span>
  </div>
  <h3 class="tc-name">{name}</h3>
  <p class="tc-desc">{description}</p>
  <div class="tc-counts">
    {contentCount > 0 && <span class="tc-count">{contentCount} resource{contentCount !== 1 ? "s" : ""}</span>}
    {conceptCount > 0 && <span class="tc-count">{conceptCount} concept{conceptCount !== 1 ? "s" : ""}</span>}
    {contentCount === 0 && conceptCount === 0 && <span class="tc-count tc-count--empty">Explore &rarr;</span>}
  </div>
</a>

<style>
  .topic-card {
    display: flex;
    flex-direction: column;
    gap: .45rem;
    padding: 1rem 1.15rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    border-left: 3px solid var(--border);
    color: var(--ink);
    transition: transform .15s ease, border-color .15s ease;
  }
  .topic-card:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
  }
  .topic-card--foundation { border-left-color: #7a4e22; }
  .topic-card--practice   { border-left-color: #2c5f6f; }
  .topic-card--context    { border-left-color: #5a6b4a; }

  .tc-header { display: flex; align-items: center; gap: .4rem; }

  .tc-code {
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .08em;
    padding: .1rem .35rem;
    border-radius: 2px;
    color: #fff;
  }
  .tc-code--foundation { background: #7a4e22; }
  .tc-code--practice   { background: #2c5f6f; }
  .tc-code--context    { background: #5a6b4a; }

  .tc-layer {
    font-family: var(--sans);
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .1em;
  }
  .tc-layer--foundation { color: #7a4e22; }
  .tc-layer--practice   { color: #2c5f6f; }
  .tc-layer--context    { color: #5a6b4a; }

  .tc-name {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
  }

  .tc-desc {
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--ink-soft);
    line-height: 1.45;
    margin: 0;
    flex: 1;
  }

  .tc-counts {
    display: flex;
    gap: .6rem;
    margin-top: .2rem;
  }

  .tc-count {
    font-family: var(--sans);
    font-size: .7rem;
    color: var(--muted);
  }
  .tc-count--empty { color: var(--accent); font-weight: 500; }
</style>
